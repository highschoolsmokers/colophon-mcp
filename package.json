{
  "name": "colophon-mcp",
  "version": "1.0.0",
  "description": "MCP server for looking up books across retailers, libraries, and electronic sources",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "web": "tsx src/web.ts",
    "dev:web": "tsx --watch src/web.ts",
    "test": "vitest run"
