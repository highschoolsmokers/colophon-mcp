# Colophon MCP — Environment Variables
# Copy to .env and fill in values

# API keys (optional — features work without them but with lower quotas)
# EBAY_APP_TOKEN=your_ebay_oauth_token
# GOOGLE_BOOKS_API_KEY=your_google_books_key

# Timeouts (ms)
# API_TIMEOUT=5000
# COVER_TIMEOUT=5000
# PROBE_TIMEOUT=2000

# Limits
# SEARCH_LIMIT=20
# TITLE_SEARCH_LIMIT=10
# RATE_LIMIT=60

# Server
# PORT=3333
